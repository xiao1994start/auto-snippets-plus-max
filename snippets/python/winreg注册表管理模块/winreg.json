{
  "引入 winreg 注册表管理库": {
    "prefix": "im -winreg",
    "body": ["import winreg"],
    "description": ["引入 winreg 注册表管理库"]
  },
  "winreg.OpenKey 打开注册表": {
    "prefix": ".OpenKey -winreg",
    "body": [
      ".OpenKey(winreg.HKEY_LOCAL_MACHINE,",
      "    r\"SOFTWARE\"",
      "    0,  # 保留参数, 传入0即可",
      "    winreg.KEY_ALL_ACCESS,  # 访问权限, KEY_ALL_ACCESS 表示所有权限",
      ")"
    ],
    "description": ["winreg.OpenKey 打开注册表"]
  },
  "winreg.QueryValueEx 读取注册表键值": {
    "prefix": ".QueryValueEx -winreg",
    "body": [".QueryValueEx(key, r\"name\")[0]"],
    "description": ["winreg.QueryValueEx 读取注册表键值"]
  },
  "winreg.SetValueEx 写入注册表键值": {
    "prefix": ".SetValueEx -winreg",
    "body": [
      ".SetValueEx(",
      "    key,",
      "    value_name,",
      "    0,  # 保留参数, 传入0即可",
      "    winreg.REG_DWORD,  # 键值类型, REG_DWORD 表示整数, REG_SZ 表示字符串, REG_BINARY 表示二进制数据",
      "    value,",
      ")"
    ],
    "description": ["winreg.SetValueEx 写入注册表键值"]
  },
  "winreg.CloseKey 关闭注册表键": {
    "prefix": ".CloseKey -winreg",
    "body": [".CloseKey($0)"],
    "description": ["winreg.CloseKey 关闭注册表键"]
  }
}
