{
  "node|npm 临时环境设置": {
    "prefix": ["ndoePortable -node|npm", "npmPortable -node|npm"],
    "body": [
      "if exist \"%~dp0node*\" (",
      "    for /D %%i in (*node*) do (",
      "        ren \"%~dp0%%i\" \"nodejs\"",
      "    )",
      ")",
      "@set path=%path%;\"%~dp0nodejs\";\"%~dp0nodejs/node_modules\";",
      "@ECHO Node.js 版本号:",
      "call node -v",
      "@ECHO NPM 版本号:",
      "call npm -v",
      "@ECHO 检查 软件仓库位置:",
      "call npm root -g",
      ""
    ],
    "description": ["node|npm 临时环境设置"]
  },
  "npm 帮助说明": {
    "prefix": ["npm =npm.help"],
    "body": [
      "@REM npm 说明",
      "临时代理 --registry https://registry.npmmirror.com/",
      "临时代理 --registry https://registry.npm.taobao.org",
      "配置参数:{",
      "\t-G 全局安装",
      "\t-S 局部安装的插件写入package.json文件中的dependencie(默认)",
      "\t-D 局部安装的插件写入package.json文件中的devDependencie",
      "\t-O 局部安装的插件写入package.json文件中的optionalDependencie",
      "}"
    ],
    "description": ["npm帮助说明"]
  },
  "自定义npm仓库位置": {
    "prefix": ["npm_config_prefix -npm", "npm_config_node_global -npm"],
    "body": ["npm config set prefix ${1:仓库位置}"],
    "description": ["自定义npm仓库位置"]
  },
  "自定义npm缓存位置": {
    "prefix": ["npm_config_cache -npm"],
    "body": ["npm config set cache ${1:缓存位置}"],
    "description": ["自定义npm缓存位置"]
  }
}
