{
  "python.创建_激活 虚拟环境": {
    "prefix": "py -venv.activate",
    "body": [
      "@ECHO 创建虚拟环境...",
      "call python -m venv ./.venv",
      "@ECHO 创建虚拟环境完成...",
      "@ECHO 激活虚拟环境...",
      "call ./.venv/Scripts/activate.bat",
      "@ECHO 安装Jupyter内核ipykernel依赖库...",
      "call python -m pip install ipykernel -i https://pypi.tuna.tsinghua.edu.cn/simple",
      "",
      "@ECHO 安装依赖库...",
      "$0",
      "",
      "call python -m pip freeze  > requirements.txt"
    ],
    "description": ["创建_激活 虚拟环境"]
  },
  "pip.Jupyter内核ipykernel依赖库": {
    "prefix": ["pip -Jupyter", "pip -ipykernel"],
    "body": [
      "@ECHO 安装Jupyter内核ipykernel依赖库...",
      "call python -m pip install ipykernel -i https://pypi.tuna.tsinghua.edu.cn/simple"
    ],
    "description": ["pip.Jupyter内核ipykernel依赖库"]
  },
  "pip.镜像源": {
    "prefix": "pip -config.index-url",
    "body": [
      "@ECHO 重置pip.ini...",
      "@REM ECHO.> %USERPROFILE%/AppData/Roaming/pip/pip.ini",
      "echo 清华",
      "call python -m pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple",
      "call python -m pip config set install.trusted-host https://pypi.tuna.tsinghua.edu.cn",
      "echo 阿里",
      "@REM call python -m pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/",
      "@REM call python -m pip config set install.trusted-host https://mirrors.aliyun.com/pypi",
      "echo 豆瓣",
      "@REM call python -m pip config set global.index-url https://pypi.douban.com/simple/",
      "@REM call python -m pip config set install.trusted-host https://pypi.douban.com"
    ],
    "description": ["pipconfig.index镜像源"]
  },
  "pip.批量镜像源": {
    "prefix": "pip -config.extra-index-url",
    "body": [
      "@ECHO 重置pip.ini...",
      "@REM ECHO.> %USERPROFILE%/AppData/Roaming/pip/pip.ini",
      "call python -m pip config set global.extra-index-url \"https: //pypi.tuna.tsinghua.edu.cn/simple http://mirrors.aliyun.com/pypi/simple http://pypi.douban.com/simple http://pypi.mirrors.ustc.edu.cn/simple\""
    ],
    "description": ["pipconfig.index批量镜像源"]
  },
