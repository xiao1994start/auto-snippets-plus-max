{
  "引入 uvicorn ASGI服务器": {
    "prefix": "im -Uvicorn",
    "body": ["# 引入 uvicorn->ASGI服务器", "import uvicorn"],
    "description": ["引入uvicorn->ASGI服务器"]
  },
  "引入 fastapi FastAPI": {
    "prefix": "im -FastAPI",
    "body": [
      "# 引入 uvicorn->ASGI服务器",
      "import uvicorn",
      "# 引入 fastapi->FastAPI服务",
      "from fastapi import FastAPI"
    ],
    "description": ["引入fastapi->FastAPI服务"]
  },
  "引入 fastapi FastAPI_all服务": {
    "prefix": "im -FastAPI.[all]",
    "body": [
      "# 引入 uvicorn->ASGI服务器",
      "import uvicorn",
      "# 引入 fastapi->FastAPI服务",
      "from fastapi import FastAPI",
      "# 引入 StaticFiles->定义静态文件",
      "from fastapi.staticfiles import StaticFiles",
      "# 引入 FileResponse->定义HTML文件, RedirectResponse->定义重定向路由地址",
      "from fastapi.responses import FileResponse, RedirectResponse"
    ],
    "description": ["引入fastapi->FastAPI_all服务"]
  },
  "引入 pywebview 创建Webview窗口": {
    "prefix": "im -Webview",
    "body": ["# 引入 pywebview 创建Webview窗口", "import webview"],
    "description": ["引入pywebview创建Webview窗口"]
  },
  "引入 Response 响应方法": {
    "prefix": "im -FastAPI.Response",
    "body": [
      "# 引入 FileResponse->定义HTML文件, RedirectResponse->定义重定向路由地址",
      "from fastapi.responses import FileResponse, RedirectResponse"
    ],
    "description": [
      "引入FileResponse->定义HTML文件, RedirectResponse->定义重定向路由地址"
    ]
  },
  "引入 StaticFiles 静态文件方法": {
    "prefix": "im -FastAPI.StaticFiles",
    "body": [
      "# 引入 StaticFiles->定义静态文件",
      "from fastapi.staticfiles import StaticFiles"
    ],
    "description": ["引入StaticFiles->定义静态文件"]
  }
}
