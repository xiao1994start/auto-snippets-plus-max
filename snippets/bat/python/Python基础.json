{
  "python.创建_激活 虚拟环境": {
    "prefix": ["py -venv.activate"],
    "body": [
      "@ECHO 创建虚拟环境...",
      "call python -m venv ./.venv",
      "@ECHO 创建虚拟环境完成...",
      "@ECHO 激活虚拟环境...",
      "call ./.venv/Scripts/activate.bat",
      "@ECHO 安装Jupyter内核ipykernel依赖库...",
      "@REM pip install --upgrade ipykernel -i https://pypi.tuna.tsinghua.edu.cn/simple",
      "",
      "@ECHO 安装依赖库...",
      "$0",
      "",
      "",
      "",
      "",
      "@ECHO 导出依赖库",
      "pip freeze  > requirements.txt",
      "",
      "@ECHO 完成!"
    ],
    "description": ["创建_激活 虚拟环境"]
  },
  "python-embed 嵌入式环境激活": {
    "prefix": ["py -embed.env"],
    "body": [
      "@ECHO OFF",
      "setlocal enabledelayedexpansion",
      "CD /D \"%~dp0\"",
      "",
      "@ECHO 修改 python*embed* 目录名为 python",
      "for /D %%i in (python*embed*) do ( ren %%i \"python\" )",
      "",
      "@ECHO 进入 python 目录(pip documentation:https://pip.pypa.io/en/stable/installation/ ^| 下载get-pip.py: https://www.python.org/downloads/windows/)",
      "CD /D \"%~dp0python\"",
      "ECHO 配置 pip 镜像",
      "ECHO [global]> \"%~dp0python\\pip.ini\"",
      "ECHO index-url = http://mirrors.aliyun.com/pypi/simple/>> \"%~dp0python\\pip.ini\"",
      "ECHO [install]>> \"%~dp0python\\pip.ini\"",
      "ECHO trusted-host=mirrors.aliyun.com>> \"%~dp0python\\pip.ini\"",
      "",
      "@ECHO 初始化 get-pip.py",
      "if not exist get-pip.py (",
      "    @ECHO get-pip.py正在下载...",
      "    curl -sSL https://bootstrap.pypa.io/get-pip.py -o \"%~dp0python\\get-pip.py\"",
      ")",
      "@ECHO 初始化环境 pip",
      "python get-pip.py -i https://pypi.tuna.tsinghua.edu.cn/simple",
      "@ECHO 修改 python*._pth 导入",
      "for %%i in (python*._pth) do (",
      "    for /F \"tokens=*\" %%j in (%%i) do (",
      "        if not \"%%j\"==\"import site\" (",
      "            ECHO %%j>> \"%~dp0python\\python._pth\"",
      "        )",
      "    )",
      "    @ECHO import site>> \"%~dp0python\\python._pth\"",
      "    del /F /Q /S %%i",
      "    ren \"%~dp0python\\python._pth\" %%i",
      ")",
      "",
      "@ECHO 环境 pip 执行",
      "CD /D \"%~dp0python/Scripts\"",
      "@ECHO 安装虚拟环境requirements.txt...",
      "@REM pip install -r \"%~dp0requirements.txt\" -i https://pypi.tuna.tsinghua.edu.cn/simple",
      "",
      "@ECHO 安装Jupyter内核ipykernel依赖库...",
      "@REM pip install --upgrade ipykernel -i https://pypi.tuna.tsinghua.edu.cn/simple",
      "",
      "@ECHO 安装依赖库...(使用虚拟环境开发时, 直接使用requirements.txt安装依赖库)",
      "",
      "",
      "",
      "",
      "",
      "",
      "@ECHO 创建嵌入式环境工作区设置",
      "if not exist \"%~dp0.vscode\" (",
      "    md \"%~dp0.vscode\"",
      ")",
      "ECHO {> \"%~dp0.vscode\\settings.json\"",
      "ECHO   \"python.defaultInterpreterPath\": \"\\${workspaceFolder}/python/python.exe\", // python Interpreter Path>> \"%~dp0.vscode\\settings.json\"",
      "ECHO   \"qtForPython.designer.path\": \"\\${workspaceFolder}/python/Scripts/pyside6-designer.exe\", // Qt Designer Path>> \"%~dp0.vscode\\settings.json\"",
      "ECHO   \"qtForPython.uic.path\": \"\\${workspaceFolder}/python/Scripts/pyside6-uic.exe\", // PySide6-uic Path>> \"%~dp0.vscode\\settings.json\"",
      "ECHO   \"qtForPython.rcc.path\": \"\\${workspaceFolder}/python/Scripts/pyside6-rcc.exe\", // PySide6-rcc Path>> \"%~dp0.vscode\\settings.json\"",
      "ECHO   \"qtForPython.qml.path\": \"\\${workspaceFolder}/python/Scripts/pyside6-qml.exe\" // PySide6-qml Path>> \"%~dp0.vscode\\settings.json\"",
      "ECHO }>> \"%~dp0.vscode\\settings.json\"",
      "",
      "@ECHO 导出依赖库",
      "pip freeze  > \"%~dp0requirements.txt\"",
      "",
      "@ECHO 完成!",
      ""
    ],
    "description": "python-embed 嵌入式环境激活"
  },
  "python-embed 嵌入式环境启动": {
    "prefix": ["call_Python_Embed"],
    "body": [
      "@ECHO 修改 python*embed* 目录名为 python",
      "for /D %%i in (python*embed*) do ( ren %%i \"python\" )",
      "",
      "CALL \"%~dp0python/python.exe\" ${1:py脚本路径} ${2:参数}"
    ],
    "description": ["python-embed 嵌入式环境启动"]
  },
  "pip.Jupyter内核ipykernel依赖库": {
    "prefix": ["pip -Jupyter", "pip -ipykernel"],
    "body": [
      "@ECHO 安装Jupyter内核ipykernel依赖库...",
      "pip install --upgrade ipykernel -i https://pypi.tuna.tsinghua.edu.cn/simple"
    ],
    "description": ["pip.Jupyter内核ipykernel依赖库"]
  },
  "pip.镜像源": {
    "prefix": "pip -config.index-url",
    "body": [
      "@ECHO 重置pip.ini...",
      "@REM ECHO.> %USERPROFILE%/AppData/Roaming/pip/pip.ini",
      "echo 清华",
      "pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple",
      "pip config set install.trusted-host https://pypi.tuna.tsinghua.edu.cn",
      "echo 阿里",
      "@REM pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/",
      "@REM pip config set install.trusted-host https://mirrors.aliyun.com/pypi",
      "echo 豆瓣",
      "@REM pip config set global.index-url https://pypi.douban.com/simple/",
      "@REM pip config set install.trusted-host https://pypi.douban.com"
    ],
    "description": ["pipconfig.index镜像源"]
  },
  "pip.批量镜像源": {
    "prefix": "pip -config.extra-index-url",
    "body": [
      "@ECHO 重置pip.ini...",
      "@REM ECHO.> %USERPROFILE%/AppData/Roaming/pip/pip.ini",
      "pip config set global.extra-index-url \"https: //pypi.tuna.tsinghua.edu.cn/simple http://mirrors.aliyun.com/pypi/simple http://pypi.douban.com/simple http://pypi.mirrors.ustc.edu.cn/simple\""
    ],
    "description": ["pipconfig.index批量镜像源"]
  },
  "pip.install 安装库": {
    "prefix": "pip -install",
    "body": [
      "pip install ${1:库名_whl文件路径} ${2:-i https://pypi.tuna.tsinghua.edu.cn/simple}"
    ],
    "description": ["pip -i 安装库"]
  },
  "pip.-reinstall 强制重装库": {
    "prefix": "pip -install.reinstall",
    "body": [
      "pip install --force-reinstall ${1:库名_whl文件路径} ${2:-i https://pypi.tuna.tsinghua.edu.cn/simple}"
    ],
    "description": ["pip -reinstall 强制重装库"]
  },
  "pip.-upgrade 升级库": {
    "prefix": "pip -install--upgrade",
    "body": [
      "pip install --upgrade ${1:pip} ${2:-i https://pypi.tuna.tsinghua.edu.cn/simple}"
    ],
    "description": ["pip --upgrade 升级库"]
  },
  "pip.uninstall 卸载": {
    "prefix": "pip -uninstall",
    "body": ["pip uninstall ${1:库名} -y"],
    "description": ["pip -uninstall 卸载"]
  },
  "pip.freeze 获取安装库列表": {
    "prefix": "pip -freeze",
    "body": ["pip freeze  > ${1:requirements.txt}"],
    "description": ["pip -freeze 获取安装库列表"]
  },
  "pip.requirements 列式安装库": {
    "prefix": ["pip -requirements.install", "pip -txt.install"],
    "body": [
      "pip install -r ${1:requirements.txt} -i https://pypi.tuna.tsinghua.edu.cn/simple"
    ],
    "description": ["pip -requirements 列式安装库"]
  }
}
