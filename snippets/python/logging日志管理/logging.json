  "引入 logging 内置日志库=>模板": {
    "prefix": "im -logging=>",
    "body": [
      "import logging",
      "from datetime import datetime",
      "from pathlib import Path",
      "",
      "",
      "# * Object: 日志输出",
      "class LOG:",
      "    \"\"\"",
      "    封装 Log 输出功能, 调用该类即可创建一个 Logger 对象.",
      "    注意:",
      "    使用前先检查",
      "    self.log_file_max_count,",
      "    self.log_level,",
      "    self.log_fmt,",
      "    self.log_datefmt,",
      "    self.log_dir,",
      "    self.log_file_name,",
      "    self.log_file,",
      "    是否需要修改.",
      "    调用 createLogger() 方法, 创建 Logger 对象.",
      "    Args:",
      "        选择不同级别来记录日志。设置一个级别，严重程度低于设置值的日志消息将被忽略",
      "            | 日志级别   丨 数值 丨",
      "            | CRITICAL  |  50  |",
      "            | ERROR     |  40  |",
      "            | WARNING   |  30  | Default level",
      "            | INFO      |  20  |",
      "            | DEBUG     |  10  |",
      "            | NOTSET    |   0  |",
      "        设置日志消息格式",
      "            | %(message)s    | 日志消息内容",
      "            | %(asctime)s    | 创建日志记录可读时间",
      "            | %(filename)s   | 调用日志记录的源文件的文件名",
      "            | %(funcName)s   | 调用日志记录的函数名",
      "            | %(levelname)s  | 当前日志记录的日志级别名称",
      "            | %(lineno)d     | 调用日志记录的源代码所在的行号",
      "            | %(module)s     | 调用日志记录的源代码所在的模块名",
      "            | %(pathname)s   | 调用日志记录的源代码所在的完整路径名",
      "            | %(process)d    | 当前进程ID",
      "            | %(thread)d     | 当前线程ID",
      "            | %(threadName)s | 当前线程名",
      "            | %(exc_info)s   | 异常信息",
      "            | %(exc_text)s   | 异常信息",
      "            | %(stack_info)s | 堆栈信息",
      "    Returns:",
      "        Logger: 返回 Logger 对象.",
      "    \"\"\"",
      "",
      "    # * class signal",
      "    def __init__(self) -> None:",
      "        # ! 限制 Log 日志文件数量的最大值",
      "        self.log_file_max_count: int = 10",
      "        # ! 定义 logging 输出等级",
      "        self.log_level: int = logging.INFO",
      "        # ! 标准化日志输出格式",
      "        self.log_fmt = \"%(asctime)s %(levelname)s %(filename)s %(lineno)d | [%(module)s.%(funcName)s] %(message)s\"",
      "        self.log_datefmt = \"%Y-%m-%d %H:%M:%S\"",
      "        # ! 创建日志文件夹 & 日志文件",
      "        self.log_dir = Path(Path(__file__).parent.absolute(), log_dir)",
      "        if not self.log_dir.exists():",
      "            self.log_dir.mkdir(parents=True, exist_ok=True)",
      "        self.log_file_name = f'Log_{datetime.now().strftime('%Y-%m-%d')}.txt'",
      "        self.log_file = Path(self.log_dir, self.log_file_name)",
      "        # * 创建 Logger 对象 & 设置 Logger 输出等级",
      "        self.logger = logging.getLogger(__name__)",
      "        self.logger.setLevel(self.log_level)",
      "        # * 创建文件输出 Handler & 设置 Handler 输出等级",
      "        self.log_handler = logging.FileHandler(self.log_file, encoding=\"utf-8\")",
      "        self.log_handler.setLevel(self.log_level)",
      "        # * 设置 Handler 输出格式",
      "        self.log_format = logging.Formatter(",
      "            fmt=self.log_fmt, datefmt=self.log_datefmt",
      "        )",
      "        self.log_handler.setFormatter(self.log_format)",
      "        # * 将 Handler 添加到 Logger 中",
      "        self.logger.addHandler(self.log_handler)",
      "        # * 配置 basicConfig 参数 (终端输出)",
      "        logging.basicConfig(",
      "            format=self.log_fmt, datefmt=self.log_datefmt, level=self.log_level",
      "        )",
      "",
      "    # # * Class Function: 输出 logger.info 日志 终端 & 文件",
      "    def createLogger(self):",
      "        # * 如果 Log 文件夹存在, 获取所有 Log*.txt 文件 -> list",
      "        if self.log_dir.exists():",
      "            log_files = list(self.log_dir.glob(\"Log*.txt\"))",
      "        # * 限制输出 log 文件的数量 -> 删除最旧的 Log*.txt 文件",
      "        if len(log_files) > self.log_file_max_count:",
      "            for i in range(len(log_files) - self.log_file_max_count):",
      "                log_files[i].unlink(missing_ok=False)",
      "        return self.logger",
      "",
      ""
    ],
    "description": "引入 logging 内置日志库=>模板"
  },
