{
  "导入 PyInstaller 打包模块": {
    "prefix": "im -PyInstaller",
    "body": [
      "import shutil",
      "from pathlib import Path",
      "from PyInstaller import __main__ as pyinstaller  # 导入PyInstaller模块",
      "# 指定打包文件名称",
      "file_name= 'main'",
      "# 删除 build, dist 目录和 *.spec 文件",
      "BASE_DIR = Path(__file__).parent.absolute()",
      "if Path(BASE_DIR,'build').exists():",
      "    shutil.rmtree(Path(BASE_DIR,'build'))",
      "if Path(BASE_DIR,'dist').exists():",
      "    shutil.rmtree(Path(BASE_DIR,'dist'))",
      "if Path(BASE_DIR,f'{file_name}.spec').exists():",
      "    Path(BASE_DIR,f'{file_name}.spec').unlink()",
      "",
      "if __name__ == '__main__':",
      "    pyinstaller.run(",
      "        [",
      "            f'{file_name}.py',  # 入口文件",
      "            '${1|-F,-D|}',  # -F:创建一个绑定的可执行文件(单文件打包_小项目), -D:创建一个包含可执行文件的单文件夹包(默认情况下_大项目)",
      "            # '-n',  # -n:文件名",
      "            # 'packFileName',  # 打包文件名",
      "            '-v'  # -v:版本号",
      "            '0.0.0.1',  # 版本号",
      "            # '--uac-admin',  # 需求管理员权限",
      "            '--clean',  # 每次打包前, 清除 build 和 dist 目录",
      "            '--noconfirm',  # 无需用户确认",
      "            '--add-data',",
      "            # --add-data: 要添加到应用程序中的附加数据文件或包含数据文件的目录",
      "            # 示例:'source:dest_dir'",
      "            #     source 是要收集的文件(或目录)的路径",
      "            #     dest_dir 是相对于应用程序顶层目录的目标目录",
      "            #     两个路径之间用冒号(:)分隔",
      "            #     要将文件放入应用程序顶层目录, 使用 . 作为 dest_dir. 该选项可多次使用",
      "            'static:static',  # 静态文件",
      "            # '-w',  # 仅使用窗口, 不提供用于标准i/o的控制台窗口",
      "            '--icon',  # 可执行文件的icon图标路径",
      "            'icon.ico',  # icon图标路径",
      "        ]",
      "    )",
      ""
    ],
    "description": ["导入PyInstaller打包模块"]
  }
}
